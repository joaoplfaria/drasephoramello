---
import { clinic } from "@data/clinic";
import SectionTitle from "@components/ui/SectionTitle.astro";
---

<section id="localizacao" class="bg-ivory-50 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <SectionTitle
      title="Localização"
      subtitle="Venha nos visitar! Estamos no centro de Palhoça"
    />

    <div class="grid gap-8 lg:grid-cols-2">
      <div class="space-y-8">
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <h3 class="mb-4 flex items-center gap-2 font-heading text-lg font-semibold text-olive-900">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 text-olive-600" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            Endereço
          </h3>
          <p class="leading-relaxed text-warm-600">
            {clinic.address.street}<br />
            {clinic.address.neighborhood}, {clinic.address.city} - {clinic.address.state}<br />
            {clinic.address.zip}
          </p>
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${clinic.address.mapsQuery}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-olive-600 transition-colors hover:text-olive-800"
          >
            Abrir no Google Maps
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <h3 class="mb-4 flex items-center gap-2 font-heading text-lg font-semibold text-olive-900">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 text-olive-600" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            Horário de Funcionamento
          </h3>
          <div class="space-y-2">
            {
              clinic.hours.map((item) => (
                <div class="flex items-center justify-between border-b border-olive-50 py-2 last:border-0">
                  <span class="text-sm text-warm-600">{item.day}</span>
                  <span
                    class={`text-sm font-medium ${item.time === "Fechada" ? "text-warm-400" : "text-olive-700"}`}
                  >
                    {item.time}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <h3 class="mb-4 flex items-center gap-2 font-heading text-lg font-semibold text-olive-900">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 text-olive-600" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
            </svg>
            Telefone
          </h3>
          <a
            href={clinic.phone.href}
            class="text-lg font-medium text-olive-700 transition-colors hover:text-olive-900"
          >
            {clinic.phone.display}
          </a>
        </div>
      </div>

      <div class="overflow-hidden rounded-2xl shadow-sm">
        <iframe
          title="Localização da clínica no mapa"
          src={`https://www.google.com/maps?q=${clinic.address.mapsQuery}&output=embed`}
          width="100%"
          height="100%"
          style="border:0; min-height: 400px;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
