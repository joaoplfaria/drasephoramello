---
import { clinic } from "@data/clinic";
import SectionTitle from "@components/ui/SectionTitle.astro";
---

<section id="agendar" class="bg-olive-50 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <SectionTitle
      title="Agende sua Consulta"
      subtitle="Preencha o formulário abaixo e envie sua mensagem diretamente pelo WhatsApp"
    />

    <div class="mx-auto max-w-lg">
      <form id="schedule-form" class="space-y-5 rounded-2xl bg-white p-6 shadow-sm md:p-8">
        <div>
          <label for="patient-name" class="mb-1.5 block text-sm font-medium text-olive-800">
            Nome do paciente
          </label>
          <input
            type="text"
            id="patient-name"
            name="name"
            required
            placeholder="Seu nome completo"
            class="w-full rounded-xl border border-olive-200 bg-ivory-50 px-4 py-3 text-sm text-warm-800 outline-none transition-colors placeholder:text-warm-400 focus:border-olive-400 focus:ring-2 focus:ring-olive-200"
          />
        </div>

        <div>
          <label for="patient-phone" class="mb-1.5 block text-sm font-medium text-olive-800">
            Telefone
          </label>
          <input
            type="tel"
            id="patient-phone"
            name="phone"
            required
            placeholder="(00) 00000-0000"
            class="w-full rounded-xl border border-olive-200 bg-ivory-50 px-4 py-3 text-sm text-warm-800 outline-none transition-colors placeholder:text-warm-400 focus:border-olive-400 focus:ring-2 focus:ring-olive-200"
          />
        </div>

        <div>
          <label for="patient-neighborhood" class="mb-1.5 block text-sm font-medium text-olive-800">
            Bairro
          </label>
          <input
            type="text"
            id="patient-neighborhood"
            name="neighborhood"
            required
            placeholder="Seu bairro"
            class="w-full rounded-xl border border-olive-200 bg-ivory-50 px-4 py-3 text-sm text-warm-800 outline-none transition-colors placeholder:text-warm-400 focus:border-olive-400 focus:ring-2 focus:ring-olive-200"
          />
        </div>

        <div>
          <label for="patient-reason" class="mb-1.5 block text-sm font-medium text-olive-800">
            Motivo do contato
          </label>
          <select
            id="patient-reason"
            name="reason"
            class="w-full rounded-xl border border-olive-200 bg-ivory-50 px-4 py-3 text-sm text-warm-800 outline-none transition-colors focus:border-olive-400 focus:ring-2 focus:ring-olive-200"
          >
            {clinic.scheduleReasons.map((reason) => (
              <option value={reason} selected={reason === "Outros"}>
                {reason}
              </option>
            ))}
          </select>
        </div>

        <button
          type="submit"
          class="flex w-full cursor-pointer items-center justify-center gap-2 rounded-full bg-[#25D366] px-6 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-[#1da851] active:bg-[#178a43]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.917.918l4.462-1.494A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.94 9.94 0 01-5.39-1.583l-.376-.228-2.653.888.887-2.646-.236-.381A9.935 9.935 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z" />
          </svg>
          Enviar via WhatsApp
        </button>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ whatsappNumber: clinic.whatsapp.number }}>
  const form = document.getElementById("schedule-form");

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    const name = document.getElementById("patient-name").value.trim();
    const phone = document.getElementById("patient-phone").value.trim();
    const neighborhood = document.getElementById("patient-neighborhood").value.trim();
    const reason = document.getElementById("patient-reason").value;

    const message =
      `Olá! Gostaria de agendar uma consulta.\n\n` +
      `*Nome:* ${name}\n` +
      `*Telefone:* ${phone}\n` +
      `*Bairro:* ${neighborhood}\n` +
      `*Motivo:* ${reason}`;

    const encoded = encodeURIComponent(message);
    window.open(`https://wa.me/${whatsappNumber}?text=${encoded}`, "_blank");
  });
</script>
