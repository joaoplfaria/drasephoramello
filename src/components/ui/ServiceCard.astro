---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;

const icons: Record<string, string> = {
  orthodontics: `<path d="M4 18h2a2 2 0 002-2v-2a2 2 0 012-2h4a2 2 0 012 2v2a2 2 0 002 2h2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M8 6a4 4 0 018 0" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>`,
  whitening: `<path d="M12 3v1m0 16v1m-7.07-2.93l.7-.7m12.74-12.74l.7-.7M3 12h1m16 0h1m-2.93 7.07l-.7-.7M5.64 5.64l-.7-.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M10 12l1.5 1.5L14 10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
  cleaning: `<path d="M7 3h10l-1 5H8L7 3z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M8.5 8v10a3 3 0 003 3h1a3 3 0 003-3V8" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M10 12h4M10 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  restoration: `<rect x="3" y="8" width="18" height="8" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M7 8V6a5 5 0 0110 0v2" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  prosthetics: `<path d="M5 12a7 7 0 0114 0" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M9 12v4a3 3 0 006 0v-4" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="9" cy="9" r="1.5" fill="currentColor"/><circle cx="15" cy="9" r="1.5" fill="currentColor"/>`,
  aesthetics: `<path d="M12 3l2.5 5.5L20 10l-4 4 1 5.5L12 17l-5 2.5 1-5.5-4-4 5.5-1.5L12 3z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>`,
};
---

<div
  class="group rounded-2xl border border-olive-100 bg-white p-6 shadow-sm transition-all duration-300 hover:border-olive-300 hover:shadow-md"
>
  <div
    class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-olive-100 text-olive-700 transition-colors group-hover:bg-olive-600 group-hover:text-white"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class="h-7 w-7"
      set:html={icons[icon] || icons.orthodontics}
    />
  </div>
  <h3 class="mb-2 font-heading text-lg font-semibold text-olive-900">
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-warm-500">
    {description}
  </p>
</div>
