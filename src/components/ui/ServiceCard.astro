---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;

const icons: Record<string, string> = {
  orthodontics: `<path d="M12 2c-2.5 0-4 2-4.5 4.5-.4 2 .1 4 .8 5.8l1.2 4.2c.5 1.5 1.2 2.8 1.8 3.3.4.2.5.2.7.2s.3 0 .7-.2c.6-.5 1.3-1.8 1.8-3.3l1.2-4.2c.7-1.8 1.2-3.8.8-5.8C16 4 14.5 2 12 2z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M6 9h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="10" y="7" width="4" height="4" rx=".5" stroke="currentColor" stroke-width="1.2" fill="none"/>`,
  whitening: `<path d="M12 6c-2 0-3.2 1.5-3.6 3.2-.3 1.5 0 3 .6 4.3l.8 2.8c.4 1.2.8 2 1.5 2.5.3.2.5.2.7.2s.4 0 .7-.2c.7-.5 1.1-1.3 1.5-2.5l.8-2.8c.6-1.3.9-2.8.6-4.3C15.2 7.5 14 6 12 6z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M19 2v3M17.5 3.5h3M5 2v3M3.5 3.5h3M20 8v2M19 9h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  cleaning: `<circle cx="12" cy="6" r="4.5" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 10.5V22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 4.5c1-1 3-1 4 0" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>`,
  restoration: `<path d="M12 2c-2.5 0-4 2-4.5 4.5-.4 2 .1 4 .8 5.8l1.2 4.2c.5 1.5 1.2 2.8 1.8 3.3.4.2.5.2.7.2s.3 0 .7-.2c.6-.5 1.3-1.8 1.8-3.3l1.2-4.2c.7-1.8 1.2-3.8.8-5.8C16 4 14.5 2 12 2z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M12 6v5M9.5 8.5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  prosthetics: `<path d="M9 2h6l-.5 5h-5L9 2z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M10.5 7v2h3V7" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9.5 11h5M10 13.5h4M10.5 16h3M11 18.5h2M11.5 21h1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  aesthetics: `<path d="M4 13a8 8 0 0116 0" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M6 14c1 3.5 3 5 6 5s5-1.5 6-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M6 14h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M9 14v2.5M12 14v3.5M15 14v2.5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/><path d="M20 3v2M19 4h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
};
---

<div
  class="group rounded-2xl border border-olive-100 bg-white p-6 shadow-sm transition-all duration-300 hover:border-olive-300 hover:shadow-md"
>
  <div
    class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-olive-100 text-olive-700 transition-colors group-hover:bg-olive-600 group-hover:text-white"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class="h-7 w-7"
      set:html={icons[icon] || icons.orthodontics}
    />
  </div>
  <h3 class="mb-2 font-heading text-lg font-semibold text-olive-900">
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-warm-500">
    {description}
  </p>
</div>
