---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, subtitle, align = "center" } = Astro.props;

const alignClass = align === "center" ? "text-center" : "text-left";
const barAlign = align === "center" ? "mx-auto" : "";
---

<div class={`mb-10 md:mb-14 ${alignClass}`}>
  <h2 class="font-heading text-3xl font-semibold text-olive-900 md:text-4xl">
    {title}
  </h2>
  <div class={`mt-3 h-1 w-16 rounded-full bg-olive-400 ${barAlign}`}></div>
  {
    subtitle && (
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-warm-500 md:text-lg mx-auto">
        {subtitle}
      </p>
    )
  }
</div>
