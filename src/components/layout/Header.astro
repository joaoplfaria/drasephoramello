---
import { clinic } from "@data/clinic";

const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: "Início", href: "#inicio" },
  { label: "Sobre", href: "#sobre" },
  { label: "Serviços", href: "#servicos" },
  { label: "Agendar", href: "#agendar" },
  { label: "Localização", href: "#localizacao" },
];
---

<header
  class="fixed top-0 right-0 left-0 z-50 border-b border-olive-100 bg-ivory-50/95 backdrop-blur-sm"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="#inicio" class="flex items-center gap-2">
      <img
        src={`${base}images/logo.png`}
        alt={`Logo ${clinic.name}`}
        class="h-10 w-10"
        width="40"
        height="40"
      />
      <span class="font-heading text-lg font-semibold text-olive-800">
        {clinic.name}
      </span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Navegação principal">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-warm-600 transition-colors hover:text-olive-700"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={clinic.whatsapp.url}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-olive-600 px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-olive-700"
      >
        Agendar Consulta
      </a>
    </nav>

    <button
      id="mobile-menu-btn"
      class="flex flex-col gap-1.5 md:hidden"
      aria-label="Abrir menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-warm-700 transition-all" id="bar1"></span>
      <span class="block h-0.5 w-6 bg-warm-700 transition-all" id="bar2"></span>
      <span class="block h-0.5 w-6 bg-warm-700 transition-all" id="bar3"></span>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-olive-100 bg-ivory-50 md:hidden"
    aria-label="Menu mobile"
  >
    <div class="flex flex-col px-4 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link border-b border-olive-50 py-3 text-sm font-medium text-warm-600 transition-colors hover:text-olive-700"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={clinic.whatsapp.url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 rounded-full bg-olive-600 px-5 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-olive-700"
      >
        Agendar Consulta
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;

  btn.addEventListener("click", () => {
    const isOpen = menu.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
    bar1.classList.toggle("translate-y-[4px]");
    bar1.classList.toggle("rotate-45");
    bar2.classList.toggle("opacity-0");
    bar3.classList.toggle("-translate-y-[4px]");
    bar3.classList.toggle("-rotate-45");
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
      bar1.classList.remove("translate-y-[4px]", "rotate-45");
      bar2.classList.remove("opacity-0");
      bar3.classList.remove("-translate-y-[4px]", "-rotate-45");
    });
  });
</script>
