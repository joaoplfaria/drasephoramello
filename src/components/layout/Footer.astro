---
import { clinic } from "@data/clinic";
---

<footer class="border-t border-olive-100 bg-olive-950 text-warm-300">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <h3 class="mb-3 font-heading text-lg font-semibold text-ivory-100">
          {clinic.name}
        </h3>
        <p class="text-sm leading-relaxed text-warm-400">
          {clinic.doctor}
        </p>
        <p class="mt-1 text-sm leading-relaxed text-warm-400">
          {clinic.description}
        </p>
      </div>

      <div>
        <h3 class="mb-3 font-heading text-lg font-semibold text-ivory-100">
          Contato
        </h3>
        <div class="space-y-2 text-sm text-warm-400">
          <p>
            <a href={clinic.phone.href} class="transition-colors hover:text-olive-300">
              {clinic.phone.display}
            </a>
          </p>
          <p>
            <a
              href={clinic.whatsapp.url}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-olive-300"
            >
              WhatsApp
            </a>
          </p>
          <p>
            <a
              href={clinic.instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-olive-300"
            >
              Instagram
            </a>
          </p>
        </div>
      </div>

      <div>
        <h3 class="mb-3 font-heading text-lg font-semibold text-ivory-100">
          Endereço
        </h3>
        <p class="text-sm leading-relaxed text-warm-400">
          {clinic.address.street}<br />
          {clinic.address.neighborhood}, {clinic.address.city} - {clinic.address.state}<br />
          {clinic.address.zip}
        </p>
      </div>
    </div>

    <div class="mt-10 border-t border-warm-800 pt-6 text-center text-sm text-warm-500">
      <p>&copy; {new Date().getFullYear()} {clinic.name}. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
