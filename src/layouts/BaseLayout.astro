---
import "@styles/global.css";
import { clinic } from "@data/clinic";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${clinic.name} | ${clinic.doctor} - Odontologia`,
  description = `${clinic.name} - Clínica odontológica da ${clinic.doctor} em ${clinic.address.city}/${clinic.address.state}. Tratamentos modernos com atendimento humanizado para o seu melhor sorriso.`,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(`${base}images/logo.png`, Astro.site)} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href={`${base}images/logo.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-ivory-50 font-sans text-warm-800 antialiased">
    <slot />
  </body>
</html>
